PORT=8787
NODE_ENV=development

# JSON string of your Google service account credentials
# You can also use GOOGLE_SERVICE_ACCOUNT_JSON_BASE64 instead
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Spreadsheet IDs
SPREADSHEET_LOG_ID=
SPREADSHEET_AUTOS_ID=
SPREADSHEET_FIXED_ID=
SPREADSHEET_RECUERDOS_ID=
SPREADSHEET_RSM_ID=
SPREADSHEET_ACCOUNTS_ID=
SPREADSHEET_AI_MIRROR_ID=

# Mirror behavior
AI_MIRROR_SHEET_NAME=Finance AI Mirror
AI_MIRROR_SHARE_EMAIL=

# Optional bridge to persist AI mirror changes into Engram (via webhook)
ENGRAM_WEBHOOK_URL=
ENGRAM_WEBHOOK_TOKEN=

# Security for HTTP API
API_TOKEN=
WIDGET_TOKEN=
